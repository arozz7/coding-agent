# ============================================================
# Local Coding Agent — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
#
# All variables have safe defaults for local development.
# Variables marked REQUIRED must be set to run the feature.
# ============================================================

# ------------------------------------------------------------
# LLM Backend (LM Studio / Ollama / any OpenAI-compatible API)
# ------------------------------------------------------------
# Endpoint served by LM Studio (default port 1234).
# Used in config/models.yaml as ${LM_STUDIO_URL}.
LM_STUDIO_URL=http://127.0.0.1:1234

# ------------------------------------------------------------
# Discord bot (REQUIRED for bot functionality)
# ------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Polling interval for live status updates (seconds)
BOT_POLL_INTERVAL=5

# ------------------------------------------------------------
# FastAPI server
# ------------------------------------------------------------
PORT=5005
# NOTE: Use 127.0.0.1, NOT localhost — on Windows 11, localhost resolves
# to ::1 (IPv6) but uvicorn binds IPv4 only, causing connection failures.
AGENT_API_URL=http://127.0.0.1:5005

# Optional API key for mutating endpoints (POST /task, /workspace/project, etc.).
# When set, callers must send X-API-Key: <value> in the request header.
# Leave empty to disable auth (safe for local-only dev).
# AGENT_API_KEY=

# Workspace root — where the agent reads/writes files.
WORKSPACE_PATH=./workspace

# Active project subdirectory within WORKSPACE_PATH (optional).
# When set, all agent file operations are scoped to WORKSPACE_PATH/PROJECT_DIR.
# Change this whenever you switch projects, or use !project in Discord.
# PROJECT_DIR=my-project

# Comma-separated allowed CORS origins (no trailing slash).
# CORS_ORIGINS=http://localhost:3000,http://localhost:5005

# ------------------------------------------------------------
# Cloud model API keys (optional — only for cloud models)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — cloud proxy for 200+ models (openrouter.ai)
# Set this key, then add entries in config/models.yaml with
#   type: remote
#   endpoint: https://openrouter.ai/api/v1
#   api_key_env: OPENROUTER_API_KEY
# OPENROUTER_API_KEY=sk-or-...

# ------------------------------------------------------------
# Search API (optional — DuckDuckGo is always-on fallback)
# ------------------------------------------------------------
# Priority: Brave → DuckDuckGo → Google (last resort)
#
# Brave Search API — RECOMMENDED primary (2 000 free queries/month, full web)
# Sign up: https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=BSAx...
#
# Google Custom Search — DEPRECATED for full-web search as of Jan 2026.
# Existing "Search entire web" engines work until Jan 1 2027.
# New engines are site-search only (max 50 domains).
# Only useful if you have an old engine with full-web still enabled.
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=

# ------------------------------------------------------------
# Storage paths (defaults work for most setups)
# ------------------------------------------------------------
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma_db
SESSION_DB_PATH=./data/memory.db
JOBS_DB_PATH=./data/jobs.db

# ------------------------------------------------------------
# Agent behaviour
# ------------------------------------------------------------
# Maximum fix-loop iterations the developer agent attempts before giving up.
# Increase for complex projects with many build errors; decrease to fail fast.
# MAX_FIX_ITERATIONS=50

# Comma-separated path prefixes the fix loop skips when reading source files.
# Add any compiled/generated output directories for your project here.
# SKIP_PATH_PREFIXES=dist/,build/,node_modules/,.cache/

# ------------------------------------------------------------
# Supervisor process manager
# ------------------------------------------------------------
# Seconds to wait for GET /health to return 200 after starting the API.
# API_STARTUP_TIMEOUT=120

# Seconds between stopping and restarting services during a restart cycle.
# RESTART_DELAY_SECS=3

# Python interpreter for the Discord bot subprocess.
# Set this when the bot's dependencies (discord.py, etc.) are installed in
# a different venv than the API server.
# BOT_PYTHON=C:/Python313/python.exe

# ------------------------------------------------------------
# External tool overrides (auto-detected if not set)
# ------------------------------------------------------------
# Additional directories to add to the shell tool's PATH, comma-separated.
# Use this when npm, node, cargo, etc. are installed in non-standard locations
# that the auto-discovery scan doesn't cover.
# EXTRA_PATH=C:/custom/tools/bin,C:/another/dir

# Override where Playwright looks for browser binaries.
# PLAYWRIGHT_BROWSERS_PATH=

# Override the git binary path.
# GIT_PATH=

# Override the Node.js binary path (optional, for MCP tools).
# NODE_PATH=

# ------------------------------------------------------------
# Observability / cost tracking
# ------------------------------------------------------------
LOG_LEVEL=INFO
# Set to false to use human-readable console logs instead of JSON.
LOG_JSON=true

RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=1.5

COST_DAILY_LIMIT=10.00
COST_MONTHLY_LIMIT=100.00
